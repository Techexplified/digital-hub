{% if customer %}
<div id="digital-download-cta" style="
  background: #f0fdf4;
  border: 1px solid #bbf7d0;
  border-radius: 12px;
  padding: 24px;
  text-align: center;
  margin: 24px 0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
">
  <div style="font-size: 28px; margin-bottom: 12px;">🎉</div>
  <h2 style="margin: 0 0 8px; font-size: 20px; font-weight: 600; color: #166534;">
    {{ block.settings.success_title }}
  </h2>
  <p style="margin: 0 0 20px; color: #4b5563; font-size: 14px;">
    {{ block.settings.success_message }}
  </p>
  <a href="/apps/digital-hub/vault" style="
    display: inline-block;
    background: #16a34a;
    color: white;
    padding: 12px 28px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 15px;
    transition: background 0.2s;
  ">
    {{ block.settings.button_text }}
  </a>
</div>
{% endif %}

{% schema %}
{
  "name": "Digital Download CTA",
  "target": "section",
  "templates": ["customers/order"],
  "settings": [
    {
      "type": "text",
      "id": "success_title",
      "label": "Success Title",
      "default": "Payment Confirmed!"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success Message",
      "default": "Your digital products are ready. Access them anytime from your Digital Vault."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Go to My Downloads"
    }
  ]
}
{% endschema %}